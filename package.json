{
  "name": "@cto.af/eslint-config",
  "version": "6.2.4",
  "description": "hildjj's lint rules",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "test": "cd test; npm run test; npm run lint",
    "lint": "eslint .",
    "ci": "npm run lint && npm run test"
  },
  "keywords": [
    "lint"
  ],
  "author": "Joe Hildebrand <joe-github@cursive.net>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cto-af/eslint-config.git"
  },
  "dependencies": {
    "@eslint/json": "1.0.1",
    "@stylistic/eslint-plugin": "5.9.0",
    "eslint-plugin-n": "17.24.0",
    "eslint-plugin-redos": "4.4.5",
    "globals": "17.3.0"
  },
  "devDependencies": {
    "@cto.af/eslint-plugin-meta": "3.0.0",
    "@eslint/markdown": "^7.5.1",
    "eslint": "^10.0.1",
    "eslint-plugin-ava": "^16.0.0",
    "eslint-plugin-jsdoc": "^62.7.0",
    "eslint-plugin-mocha": "11.2.0",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.56.0"
  },
  "packageManager": "pnpm@10.30.1",
  "pnpm": {
    "overrides": {
      "eslint@10.0.1>ajv": "6.14.0",
      "enhance-visitors@1.0.0>lodash": "4.17.23",
      "@typescript-eslint/typescript-estree>minimatch": "10.2.2"
    }
  },
  "engines": {
    "node": ">=20"
  }
}
